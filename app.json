{
  "expo": {
    "name": "LIVRR",
    "slug": "client-livrr",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "livrr",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.livrr.client"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.livrr.client"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "a4922b4a-3280-42de-9a4f-edc315b60de0"
      }
    }
  }
}